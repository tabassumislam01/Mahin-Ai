# ============================================
# Mahin AI Backend - Environment Configuration
# ============================================

# SERVER
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# DATABASE (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mahin_ai?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_characters_here_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_min_32_characters_here
REFRESH_TOKEN_EXPIRES_IN=30d

# LOCAL AI (Ollama + Qwen)
AI_PROVIDER=ollama
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:3b
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# RESEND EMAIL
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@mahin.app

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://mahin.app

# SECURITY
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AWS/DEPLOYMENT
DOMAIN=mahin.app
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=mahin://app

# LOGGING
LOG_LEVEL=info