# ============================================
# Mahin AI - Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to repository

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=mahin://app

# ============================================
# DATABASE CONFIGURATION (MongoDB Atlas)
# ============================================
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=mahin_ai

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# AI MODEL INTEGRATION
# ============================================
AI_MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# Alternative AI Providers (uncomment as needed)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# CLAUDE_MODEL=claude-3-sonnet-20240229
# GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key

# ============================================
# CLOUDINARY (File Storage)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=mahin-ai

# ============================================
# RESEND EMAIL API
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@mahin.app
EMAIL_SUPPORT=support@mahin.app

# ============================================
# DOMAIN CONFIGURATION
# ============================================
DOMAIN=mahin.app
API_DOMAIN=api.mahin.app
WEB_DOMAIN=app.mahin.app

# ============================================
# SECURITY CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://mahin.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your_session_secret_key_here_min_32_chars
BCRYPT_ROUNDS=10

# ============================================
# AWS EC2 CONFIGURATION
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_url
MONITORING_ENABLED=false

# ============================================
# REDIS CONFIGURATION (Optional - for caching & real-time)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# PAYMENT GATEWAY (Future use)
# ============================================
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ============================================
# MOBILE APP CONFIGURATION
# ============================================
MOBILE_APP_NAME=Mahin AI
MOBILE_APP_PACKAGE_NAME=com.mahin.ai
MOBILE_APP_VERSION=1.0.0

# ============================================
# DEVELOPMENT TOOLS
# ============================================
DEBUG=mahin-ai:*
PRETTY_PRINT_LOGS=true
